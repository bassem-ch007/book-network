# Runtime stage only (JAR already built in CI)
FROM amazoncorretto:17

ARG APP_VERSION=1.0.0
ARG PROFILE=prod
ARG EMAIL_HOSTNAME=unset
ARG EMAIL_USER_NAME=unset
ARG DB_URL=unset

WORKDIR /app
COPY target/bsn-*.jar /app/
EXPOSE 8088

ENV PROFILE=${PROFILE}
ENV DB_URL=${DB_URL}
ENV APP_VERSION=${APP_VERSION}
ENV ACTIVE_PROFILE=${PROFILE}
ENV EMAIL_HOSTNAME=${EMAIL_HOSTNAME}
ENV EMAIL_USER_NAME=${EMAIL_USER_NAME}

ENTRYPOINT ["sh", "-c", "java -jar bsn-$APP_VERSION.jar"]